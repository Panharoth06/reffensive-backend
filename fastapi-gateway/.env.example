KEYCLOAK_ISSUER=http://localhost:8080/realms/go-fastapi
# Optional. If unset, audience check is skipped.
KEYCLOAK_AUDIENCE=
KEYCLOAK_WEB_CLIENT_ID=
KEYCLOAK_WEB_CLIENT_IDS=
KEYCLOAK_CLI_CLIENT_ID=cli-client
# Fetch JWKS via host-mapped Keycloak port from inside container network.
KEYCLOAK_JWKS_URL=http://host.docker.internal:8080/realms/go-fastapi/protocol/openid-connect/certs
GRPC_SERVER_ADDR=localhost:50051
REDIS_URL=redis://localhost:6379/0
SCAN_QUOTA_LIMIT=50
ANON_SCAN_QUOTA_LIMIT=3
ANON_FINGERPRINT_OVERRIDE=

# AI suggestion providers
AI_SUGGESTION_PROVIDER_NEXT_STEPS=groq
AI_SUGGESTION_GROQ_API_KEY=
AI_SUGGESTION_GEMINI_API_KEY=
AI_SUGGESTION_ANTHROPIC_API_KEY=
AI_SUGGESTION_MODEL_NEXT_STEPS=llama-3.3-70b-versatile
AI_SUGGESTION_MODEL_NEXT_STEPS_GEMINI=gemini-2.0-flash
AI_SUGGESTION_MODEL_NEXT_STEPS_ANTHROPIC=claude-3-5-haiku-20241022
AI_SUGGESTION_MODEL_ANALYSIS=gemini-2.0-flash
AI_SUGGESTION_MODEL_REPORT=claude-3-5-haiku-20241022
AI_SUGGESTION_CACHE_TTL_SECONDS=1800
AI_SUGGESTION_INTERNAL_SECRET=

# AI suggestion MCP (Model Context Provider) settings
AI_SUGGESTION_MCP_ENABLED=true
AI_SUGGESTION_MCP_CONTEXT_URL=http://localhost:8000/internal/ai/mcp/ai-suggestion/context
AI_SUGGESTION_MCP_TIMEOUT_SECONDS=10
AI_SUGGESTION_MCP_STRICT=false
AI_SUGGESTION_MCP_SECRET=your-secret-here
