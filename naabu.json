{
  "category_name": "Reconnaissance",
  "tool_name": "naabu",
  "tool_description": "Fast and configurable port scanner",
  "tool_long_description": "Naabu is a port scanning tool written in Go that allows you to run accurate and fast port scans. It uses a combination of SYN and Connect scan methods, making it ideal for network reconnaissance and security assessments.",
  "examples": [
    {
      "host": "example.com",
      "ports": "80,443,8080"
    }
  ],
  "input_schema": {
    "type": "object",
    "pipeline_input": {
      "multi_mode": "list_file",
      "list_flag": "-list",
      "target_field": "host"
    },
    "fields": [
      {
        "key": "host",
        "type": "string",
        "required": true,
        "flag": "-host",
        "description": "Target host or IP address to scan"
      },
      {
        "key": "ports",
        "type": "string",
        "required": false,
        "flag": "-ports",
        "description": "Comma-separated list of ports to scan (e.g., 80,443,8080 or 1-1000)"
      }
    ]
  },
  "output_schema": {
    "type": "array",
    "pipeline_output": {
      "mode": "jsonl",
      "extract_field": "host_port",
      "entity": "host_port",
      "dedupe": true
    },
    "fields": [
      {
        "key": "host_port",
        "type": "string",
        "label": "Open Host Port",
        "description": "Derived host:port value for chaining and display",
        "finding_host": true,
        "pipeline_extract": true
      },
      {
        "key": "host",
        "type": "string",
        "label": "Host",
        "description": "Target hostname"
      },
      {
        "key": "ip",
        "type": "string",
        "label": "IP",
        "description": "Open host IP address"
      },
      {
        "key": "port",
        "type": "integer",
        "label": "Port",
        "description": "Open port number"
      }
    ]
  },
  "scan_config": {
    "basic": {
      "presets": [
        {
          "name": "light",
          "description": "Scan top ports quickly",
          "flags": ["-top-ports", "100"]
        },
        {
          "name": "deep",
          "description": "Comprehensive port scan",
          "flags": ["-p", "1-65535"]
        }
      ]
    },
    "medium": {
      "options": [
        {
          "flag": "-rate",
          "key": "rate",
          "type": "integer",
          "description": "Packets per second to send",
          "required": false
        },
        {
          "flag": "-timeout",
          "key": "timeout",
          "type": "integer",
          "description": "Timeout in seconds",
          "required": false
        },
        {
          "flag": "-retries",
          "key": "retries",
          "type": "integer",
          "description": "Number of retries for each port",
          "required": false
        }
      ]
    },
    "advanced": {
      "options": []
    }
  },
  "install_method": "docker",
  "version": "2.5.0",
  "image_ref": "projectdiscovery/naabu:v2.5.0",
  "image_source": "dockerhub",
  "is_active": true,
  "denied_options": [
    "-list",
    "-json",
    "-csv",
    "-nmap",
    "-nmap-cli",
    "-silent"
  ],
  "shadow_output_config": {
    "preferred_format": "jsonl",
    "formats": {
      "jsonl": {
        "transport": "stdout",
        "enable_flags": ["-silent", "-json"],
        "parser": "jsonl",
        "path_mode": "streaming"
      }
    },
    "default_path": "/tmp/shadow/naabu",
    "filename_template": "{job_id}_{step_id}_{tool_name}_{timestamp}",
    "parse_timeout_seconds": 30,
    "fallback_to_stdout": true,
    "is_streaming": true
  },
  "parser_config": {
    "type": "jsonl",
    "field_mappings": {
      "host": ["host_port", "ip"],
      "title": ["host_port", "ip"]
    },
    "default_severity": "SEVERITY_INFO",
    "fingerprint_fields": ["host_port", "ip", "port"]
  }
}
