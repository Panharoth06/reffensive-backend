{
  "category_name": "Vulnerability Scanning",
  "tool_name": "nuclei",
  "tool_description": "Fast and customizable vulnerability scanner based on templates",
  "tool_long_description": "Nuclei is a fast, template-based vulnerability scanner written in Go. It uses predefined YAML templates to detect security issues across a wide range of protocols including HTTP, DNS, TCP, and more. It is designed to be used in pipeline after HTTP probing to identify known vulnerabilities, misconfigurations, and exposures.",
  "examples": [
    {
      "host": "https://example.com"
    }
  ],
  "input_schema": {
    "type": "object",
    "pipeline_input": {
      "multi_mode": "list_file",
      "list_flag": "-list",
      "target_field": "host"
    },
    "fields": [
      {
        "key": "host",
        "type": "string",
        "required": true,
        "flag": "-u",
        "description": "Target URL or host to scan"
      }
    ]
  },
  "output_schema": {
    "type": "array",
    "pipeline_output": {
      "mode": "jsonl",
      "extract_field": "matched-at",
      "entity": "vulnerability",
      "dedupe": true
    },
    "fields": [
      {
        "key": "template-id",
        "type": "string",
        "label": "Template ID",
        "description": "Nuclei template identifier"
      },
      {
        "key": "name",
        "type": "string",
        "label": "Name",
        "description": "Vulnerability name",
        "finding_title": true
      },
      {
        "key": "severity",
        "type": "string",
        "label": "Severity",
        "description": "Severity level",
        "finding_severity": true
      },
      {
        "key": "host",
        "type": "string",
        "label": "Host",
        "finding_host": true
      },
      {
        "key": "matched-at",
        "type": "string",
        "label": "Matched At",
        "description": "URL or endpoint that matched the template",
        "finding_host": true,
        "pipeline_extract": true
      },
      {
        "key": "description",
        "type": "string",
        "label": "Description",
        "description": "Vulnerability description",
        "finding_description": true
      }
    ]
  },
  "scan_config": {
    "basic": {
      "presets": [
        {
          "name": "light",
          "description": "Scan with critical and high severity templates only",
          "flags": ["-severity", "critical,high", "-etags", "dos,fuzz"]
        },
        {
          "name": "deep",
          "description": "Full scan with all templates except DoS",
          "flags": ["-severity", "critical,high,medium,low", "-etags", "dos"]
        }
      ]
    },
    "medium": {
      "options": [
        {
          "flag": "-c",
          "key": "concurrency",
          "type": "integer",
          "description": "Number of concurrent template executions",
          "required": false
        },
        {
          "flag": "-timeout",
          "key": "timeout",
          "type": "integer",
          "description": "Timeout in seconds per request",
          "required": false
        },
        {
          "flag": "-retries",
          "key": "retries",
          "type": "integer",
          "description": "Number of retries on failure",
          "required": false
        },
        {
          "flag": "-rate-limit",
          "key": "rate",
          "type": "integer",
          "description": "Maximum requests per second",
          "required": false
        },
        {
          "flag": "-severity",
          "key": "severity",
          "type": "string",
          "description": "Filter templates by severity (critical,high,medium,low,info)",
          "required": false
        },
        {
          "flag": "-tags",
          "key": "tags",
          "type": "string",
          "description": "Run templates with specific tags (e.g. cve,sqli,xss)",
          "required": false
        },
        {
          "flag": "-etags",
          "key": "exclude_tags",
          "type": "string",
          "description": "Exclude templates with specific tags (e.g. dos,fuzz)",
          "required": false
        }
      ]
    },
    "advanced": {
      "options": []
    }
  },
  "install_method": "docker",
  "version": "3.3.9",
  "image_ref": "projectdiscovery/nuclei:v3.3.9",
  "image_source": "dockerhub",
  "is_active": true,
  "denied_options": [
    "-list",
    "-csv",
    "-o",
    "-output",
    "-sarif-export",
    "-markdown-export",
    "-silent",
    "-jsonl"
  ],
  "shadow_output_config": {
    "preferred_format": "jsonl",
    "formats": {
      "jsonl": {
        "transport": "stdout",
        "enable_flags": ["-silent", "-jsonl"],
        "parser": "jsonl",
        "path_mode": "streaming"
      }
    },
    "default_path": "/tmp/shadow/nuclei",
    "filename_template": "{job_id}_{step_id}_{tool_name}_{timestamp}",
    "parse_timeout_seconds": 60,
    "fallback_to_stdout": true,
    "is_streaming": true
  },
  "parser_config": {
    "type": "jsonl",
    "field_mappings": {
      "title": ["template-id", "name"],
      "severity": "severity",
      "host": ["matched-at", "host"],
      "description": ["description"]
    },
    "fingerprint_fields": ["template-id", "matched-at", "name"]
  }
}
